            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponseAuthResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/auth/login": {
      "post": {
        "tags": ["인증"],
        "summary": "로그인",
        "description": "이메일과 비밀번호로 로그인합니다.",
        "operationId": "login",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/LoginRequest" }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponseAuthResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/members/me": {
      "get": {
        "tags": ["회원"],
        "summary": "내 정보 조회",
        "description": "현재 로그인한 회원의 정보를 조회합니다.",
        "operationId": "getMe",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponseMemberResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/health": {
      "get": {
        "tags": ["헬스체크"],
        "summary": "서버 상태 확인",
        "operationId": "health",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponseMapStringString"
                }
              }
            }
          }
        }
      }
    },
    "/api/dashboard/yearly": {
      "get": {
        "tags": ["대시보드"],
        "summary": "연간 요약",
        "description": "해당 연도의 총 수입, 총 지출, 예상 종소세, 환급/추가납부 예상액을 조회합니다. 월별 브레이크다운 포함.",
        "operationId": "getYearlySummary",
        "parameters": [
          {
            "name": "year",
            "in": "query",
            "required": true,
            "schema": { "type": "integer", "format": "int32" }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponseYearlySummaryResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/dashboard/monthly": {
      "get": {
        "tags": ["대시보드"],
        "summary": "월별 요약",
        "description": "해당 월의 총 수입, 총 지출, 원천징수액, 순수익을 조회합니다.",
        "operationId": "getMonthlySummary",
        "parameters": [
          {
            "name": "year",
            "in": "query",
            "required": true,
            "schema": { "type": "integer", "format": "int32" }
          },
          {
            "name": "month",
            "in": "query",
            "required": true,
            "schema": { "type": "integer", "format": "int32" }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponseMonthlySummaryResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "UpdateIncomeRequest": {
        "type": "object",
        "properties": {
          "clientName": { "type": "string", "minLength": 1 },
          "amount": { "type": "number" },
          "incomeDate": { "type": "string", "format": "date" },
          "memo": { "type": "string" }
        },
        "required": ["amount", "incomeDate"]
      },
      "ApiResponseIncomeResponse": {
        "type": "object",
        "properties": {
          "status": { "type": "integer", "format": "int32" },
          "message": { "type": "string" },
          "data": { "$ref": "#/components/schemas/IncomeResponse" }
        },
        "required": ["message", "status"]
      },
      "IncomeResponse": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "clientName": { "type": "string" },
          "amount": { "type": "number" },
          "withholdingTax": { "type": "number" },
          "netAmount": { "type": "number" },
          "incomeDate": { "type": "string", "format": "date" },
          "memo": { "type": "string" },
          "createdAt": { "type": "string", "format": "date-time" }
        },
        "required": [
          "amount",
          "clientName",
          "id",
          "incomeDate",
          "netAmount",
          "withholdingTax"
        ]
      },
      "UpdateExpenseRequest": {
        "type": "object",
        "properties": {
          "title": { "type": "string", "minLength": 1 },
          "amount": { "type": "number" },
          "expenseDate": { "type": "string", "format": "date" },
          "category": {
            "type": "string",
            "enum": [
              "OFFICE_SUPPLY",
              "EQUIPMENT",
              "SOFTWARE",
              "TRANSPORT",
              "MEAL",
              "EDUCATION",
              "TELECOM",
              "RENT",
              "OUTSOURCING",
              "TAX",
              "INSURANCE",
              "ETC"
            ]
          },
          "memo": { "type": "string" },
          "isDeductible": { "type": "boolean" }
        },
        "required": ["amount", "category", "expenseDate", "isDeductible"]
      },
      "ApiResponseExpenseResponse": {
        "type": "object",
        "properties": {
          "status": { "type": "integer", "format": "int32" },
          "message": { "type": "string" },
          "data": { "$ref": "#/components/schemas/ExpenseResponse" }
        },
        "required": ["message", "status"]
      },
      "ExpenseResponse": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "title": { "type": "string" },
          "amount": { "type": "number" },
          "expenseDate": { "type": "string", "format": "date" },
          "category": {
            "type": "string",
            "enum": [
              "OFFICE_SUPPLY",
              "EQUIPMENT",
              "SOFTWARE",
              "TRANSPORT",
              "MEAL",
              "EDUCATION",
              "TELECOM",
              "RENT",
              "OUTSOURCING",
              "TAX",
              "INSURANCE",
              "ETC"
            ]
          },
          "categoryDisplayName": { "type": "string" },
          "memo": { "type": "string" },
          "isDeductible": { "type": "boolean" },
          "createdAt": { "type": "string", "format": "date-time" }
        },
        "required": [
          "amount",
          "category",
          "categoryDisplayName",
          "expenseDate",
          "id",
          "isDeductible",
          "title"
        ]
      },
      "CreateIncomeRequest": {
        "type": "object",
        "properties": {
          "clientName": { "type": "string", "minLength": 1 },
          "amount": { "type": "number" },
          "incomeDate": { "type": "string", "format": "date" },
          "memo": { "type": "string" }
        },
        "required": ["amount", "incomeDate"]
      },
      "CreateExpenseRequest": {
        "type": "object",
        "properties": {
          "title": { "type": "string", "minLength": 1 },
          "amount": { "type": "number" },
          "expenseDate": { "type": "string", "format": "date" },
          "category": {
            "type": "string",
            "enum": [
              "OFFICE_SUPPLY",
              "EQUIPMENT",
              "SOFTWARE",
              "TRANSPORT",
              "MEAL",
              "EDUCATION",
              "TELECOM",
              "RENT",
              "OUTSOURCING",
              "TAX",
              "INSURANCE",
              "ETC"
            ]
          },
          "memo": { "type": "string" },
          "isDeductible": { "type": "boolean" }
        },
        "required": ["amount", "category", "expenseDate", "isDeductible"]
      },
      "WithholdingTaxRequest": {
        "type": "object",
        "properties": { "amount": { "type": "number" } },
        "required": ["amount"]
      },
      "ApiResponseWithholdingTaxResponse": {
        "type": "object",
        "properties": {
          "status": { "type": "integer", "format": "int32" },
          "message": { "type": "string" },
          "data": { "$ref": "#/components/schemas/WithholdingTaxResponse" }
        },
        "required": ["message", "status"]
      },
      "WithholdingTaxResponse": {
        "type": "object",
        "properties": {
          "grossAmount": { "type": "number" },
          "incomeTax": { "type": "number" },
          "localTax": { "type": "number" },
          "totalTax": { "type": "number" },
          "netAmount": { "type": "number" }
        },
        "required": [
          "grossAmount",
          "incomeTax",
          "localTax",
          "netAmount",
          "totalTax"
        ]
      },
      "IncomeTaxRequest": {
        "type": "object",
        "properties": {
          "annualIncome": { "type": "number" },
          "expenses": { "type": "number" },
          "expenseRate": { "type": "number" }
        },
        "required": ["annualIncome"]
      },
      "ApiResponseIncomeTaxResponse": {
        "type": "object",
        "properties": {
          "status": { "type": "integer", "format": "int32" },
          "message": { "type": "string" },
          "data": { "$ref": "#/components/schemas/IncomeTaxResponse" }
        },
        "required": ["message", "status"]
      },
      "IncomeTaxResponse": {
        "type": "object",
        "properties": {
          "annualIncome": { "type": "number" },
          "totalExpenses": { "type": "number" },
          "incomeAmount": { "type": "number" },
          "taxableIncome": { "type": "number" },
