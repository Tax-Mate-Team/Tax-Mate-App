{
  "openapi": "3.1.0",
  "info": {
    "title": "TaxMate API",
    "description": "프리랜서 세금 관리 서비스 API",
    "contact": {
      "name": "TaxMate",
      "url": "https://github.com/chunnho/TaxMate-Be"
    },
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "http://taxmate-prod.us-east-1.elasticbeanstalk.com",
      "description": "Generated server url"
    }
  ],
  "tags": [
    {
      "name": "지출 관리",
      "description": "지출 등록, 조회, 수정, 삭제 (로그인 필요)"
    },
    {
      "name": "수입 관리",
      "description": "수입 등록, 조회, 수정, 삭제 (로그인 필요)"
    },
    { "name": "인증", "description": "회원가입, 로그인, 토큰 갱신" },
    {
      "name": "대시보드",
      "description": "월별/연간 수입/지출/세금 요약 (로그인 필요)"
    },
    { "name": "회원", "description": "내 정보 조회/수정" },
    {
      "name": "세금 계산기",
      "description": "로그인 없이 사용 가능한 세금 계산 API"
    },
    { "name": "헬스체크", "description": "서버 상태 확인" }
  ],
  "paths": {
    "/api/incomes/{incomeId}": {
      "get": {
        "tags": ["수입 관리"],
        "summary": "수입 상세 조회",
        "description": "수입 내역 1건을 조회합니다.",
        "operationId": "getIncome",
        "parameters": [
          {
            "name": "incomeId",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponseIncomeResponse"
                }
              }
            }
          }
        }
      },
      "put": {
        "tags": ["수입 관리"],
        "summary": "수입 수정",
        "description": "수입 내역을 수정합니다.",
        "operationId": "updateIncome",
        "parameters": [
          {
            "name": "incomeId",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/UpdateIncomeRequest" }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponseIncomeResponse"
                }
              }
            }
          }
        }
      },
      "delete": {
        "tags": ["수입 관리"],
        "summary": "수입 삭제",
        "description": "수입 내역을 삭제합니다. (소프트 삭제)",
        "operationId": "deleteIncome",
        "parameters": [
          {
            "name": "incomeId",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": { "$ref": "#/components/schemas/ApiResponse" }
              }
            }
          }
        }
      }
    },
    "/api/expenses/{expenseId}": {
